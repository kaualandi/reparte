# Reparte API — variáveis de ambiente
# Copie para .env e preencha. Não commite o .env.

# String de conexão Postgres. O schema "reparte" é criado pela migration.
DATABASE_URL=postgresql://user:pass@localhost:5432/reparte

# URL interna do scraper de NFC-e (Elysia). Em prod no EC2, geralmente é
# http://127.0.0.1:3000 — não exponha o scraper publicamente.
SCRAPER_URL=http://localhost:3000

# Segredo HMAC dos tokens JWT estáticos. Gere com `openssl rand -base64 48`.
# CRÍTICO: se você mudar isso depois, todos os tokens distribuídos param de funcionar.
JWT_SECRET=change-me-to-a-long-random-string

# Porta HTTP do servidor da API.
PORT=3002
