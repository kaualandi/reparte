# Reverse proxy do nginx para a API do Reparte.
# Host público: reparte-api.kaualf.com
#
# Instalação no EC2:
#   sudo cp deploy/nginx.conf.example /etc/nginx/sites-available/reparte-api
#   sudo ln -sf /etc/nginx/sites-available/reparte-api /etc/nginx/sites-enabled/reparte-api
#   sudo nginx -t && sudo systemctl reload nginx
#   sudo certbot --nginx -d reparte-api.kaualf.com
server {
    listen 80;
    server_name reparte-api.kaualf.com;

    # certbot reescreve este bloco para HTTPS automaticamente após
    # `certbot --nginx -d reparte-api.kaualf.com`.
    location / {
        proxy_pass http://127.0.0.1:3002;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 60s;
    }
}
